{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sent-tech.local/onyxia/contributor-catalog/catalog-item.schema.json",
  "title": "Onyxia Contributor Catalog Item",
  "type": "object",
  "required": [
    "id",
    "kind",
    "title",
    "owner",
    "status",
    "summary",
    "links",
    "dependencies",
    "uat",
    "security",
    "runtimeHooks"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "kind": {
      "type": "string",
      "enum": [
        "service",
        "data_source",
        "api",
        "mcp_tool",
        "connector",
        "workflow",
        "iceberg_catalog"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "brainstorm",
        "spec",
        "plan",
        "uat",
        "prod",
        "blocked",
        "deprecated"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "href"],
        "additionalProperties": false,
        "properties": {
          "label": { "type": "string" },
          "href": { "type": "string" }
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      }
    },
    "security": {
      "type": "object",
      "required": ["auth", "sensitivity", "notes"],
      "additionalProperties": false,
      "properties": {
        "auth": { "type": "string" },
        "sensitivity": {
          "type": "string",
          "enum": ["public", "internal", "restricted", "unknown"]
        },
        "notes": { "type": "string" }
      }
    },
    "runtimeHooks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "target", "status"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "enum": ["helm_chart", "dag", "job", "mcp_action", "api_probe", "manual", "none"]
          },
          "target": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["draft", "planned", "available", "blocked", "not_applicable"]
          }
        }
      }
    },
    "uat": {
      "type": "object",
      "required": ["status", "checklists", "blockers"],
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["not_started", "in_progress", "passed", "blocked", "not_applicable"]
        },
        "checklists": {
          "type": "array",
          "items": { "type": "string" }
        },
        "blockers": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
