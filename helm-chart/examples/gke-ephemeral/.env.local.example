# Single source of truth for everything personal to your deployment.
# Copy to .env.local (gitignored) and fill in. All scripts under ./scripts/
# load this file via _load_env.sh and export the right TF_VAR_* + helm-template
# variables. Nothing personal lives in any tracked file.

# --- GCP ----------------------------------------------------------------------
PROJECT_ID=my-gcp-project
REGION=us-central1
CLUSTER_NAME=onyxia-test

# --- Hostnames (must resolve to the ingress-nginx LB) ------------------------
PUBLIC_HOSTNAME=onyxia.example.com
KEYCLOAK_HOSTNAME=auth.onyxia.example.com

# --- GCS data / STS bridge ---------------------------------------------------
# Enabled by default in scripts/_load_env.sh for this workpackage. The bridge
# hostname must point at the same ingress-nginx LoadBalancer as PUBLIC_HOSTNAME.
# No extra cluster or LoadBalancer is created.
# ENABLE_GCS_STORAGE=true
# GCS_DATA_BUCKET=my-gcp-project-onyxia-data
# GCS_POLARIS_WAREHOUSE_BUCKET=my-gcp-project-onyxia-warehouse
# STS_BRIDGE_HOSTNAME=sts.onyxia.example.com
# STS_BRIDGE_IMAGE=ghcr.io/rhanka/onyxia-gcs-sts-bridge:latest

# --- Let's Encrypt -----------------------------------------------------------
LETSENCRYPT_EMAIL=me@example.com

# --- Google OAuth client (reused by oauth2-proxy AND Keycloak's Google IdP) --
# Create a Web OAuth client in Google Cloud Console, then:
#   kubectl -n onyxia create secret generic onyxia-oauth2-proxy \
#     --from-literal=client-secret=<secret> \
#     --from-literal=cookie-secret=<random 32-byte base64>
GOOGLE_OAUTH_CLIENT_ID=
# Comma-separated, e.g. "me@example.com,team@example.com"
GOOGLE_OAUTH_ALLOWED_EMAILS=me@example.com

# --- Keycloak ----------------------------------------------------------------
# No password here. Create the bootstrap admin secret out of band:
#   kubectl create namespace keycloak
#   kubectl -n keycloak create secret generic keycloak-bootstrap-admin \
#     --from-literal=password=<your strong password>

# --- Sentropic theme (optional) ----------------------------------------------
# Set ENABLE_SENTROPIC_THEME=true to make the deploy run
# helm-chart/examples/gke-ephemeral/theme/sentropic-to-onyxia.mjs at the start
# of every apply, splicing PALETTE_OVERRIDE_*, FONT, HEADER_LOGO,
# HEADER_TEXT_BOLD/FOCUS, TAB_TITLE and FAVICON into web.env.
# Default false → Onyxia keeps the upstream InseeFrLab look.
ENABLE_SENTROPIC_THEME=false

# Required when ENABLE_SENTROPIC_THEME=true (otherwise ignored):
SENTROPIC_HEADER_LOGO_URL=https://cdn.example.com/onyxia-logo.svg
SENTROPIC_HEADER_TEXT_BOLD=your-brand
SENTROPIC_HEADER_TEXT_FOCUS=Datalab

# Optional overrides (defaults shown):
# SENTROPIC_TAB_TITLE="your-brand Datalab · Onyxia"
# SENTROPIC_FAVICON_URL=https://cdn.example.com/onyxia-logo.svg
# SENTROPIC_THEME_VERSION=v0.5.0
# STS_BRIDGE_IMAGE=ghcr.io/rhanka/onyxia-gcs-sts-bridge:latest
# --- Apache Polaris (Iceberg REST catalog) ----------------------------------
# Disabled by default. Flip to true once you have a Postgres bootstrap secret
# in the polaris namespace AND want to expose the catalog publicly. The
# hostname must point at the ingress-nginx LB.
#
#   kubectl create namespace polaris
#   kubectl -n polaris create secret generic polaris-db \
#     --from-literal=password=<your strong polaris-db password>
#
# ENABLE_POLARIS=true
# POLARIS_HOSTNAME=polaris.onyxia.example.com
# ENABLE_POLARIS_STORAGE=true
# POLARIS_IMAGE=apache/polaris:1.5.0
# Optional: if unset, ensure-polaris-db-secret.sh generates the password once.
# POLARIS_DB_PASSWORD=
#
# Storage wiring:
# POLARIS_WAREHOUSE_BUCKET=<project>-onyxia-warehouse
# POLARIS_WAREHOUSE_GSA_EMAIL=polaris-warehouse@<project>.iam.gserviceaccount.com
